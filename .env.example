# 모든 키가 비어 있으면 dry-run 모드로 동작합니다 (실제 API 호출 X).
# SETUP_GUIDE.md를 참고하여 각 키를 입력하세요.

# ── Anthropic (Claude) ──
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Threads (Meta Graph API) ──
# https://developers.facebook.com/docs/threads/get-started
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# ── Slack ──
# Bot Token Scopes: chat:write, chat:write.public
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL=#thread-automation
